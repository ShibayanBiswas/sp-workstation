# MongoDB Atlas connection string
# IMPORTANT on a shared cluster: always include a dedicated database name
# (…mongodb.net/sp-workstation?…) so other projects' databases are never touched.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sp-workstation?retryWrites=true&w=majority
# URL-encode special characters in the password (@ → %40, # → %23, etc.)
# For temporary local development only, use: MONGODB_URI=memory
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/sp-workstation?retryWrites=true&w=majority

# JWT secret (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# App URL (used for redirects and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Primary SP Dashboard base URL
NEXT_PUBLIC_SP_DASHBOARD_URL=https://sp-dashboard-eta.vercel.app

# Gift City AIF (Cat-III structured units backtester) embed base URL
NEXT_PUBLIC_GIFT_CITY_AIF_URL=https://gift-city-aif-backtester.vercel.app

# Options Lab (Learning & Development) embed base URL
NEXT_PUBLIC_OPTIONS_LAB_URL=https://option-strategies.vercel.app

# Option Chain Archive (Database Hub) embed base URL
NEXT_PUBLIC_OPTION_CHAIN_ARCHIVE_URL=https://option-data-fetcher.vercel.app

# JSON map of normalized team email to initial password.
# Required only while provisioning users in an environment without the
# gitignored scripts/seed-passwords.local.json file.
SEED_DEFAULT_PASSWORD_MAP={"user@rathi.com":"CHANGE_ME"}

# Optional controlled recovery switch. Never leave enabled.
# When true, seed overwrites existing password hashes — dangerous on shared envs.
FORCE_RESET_PASSWORDS=false
