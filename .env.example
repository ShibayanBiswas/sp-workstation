# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sp-workstation?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/sp-workstation?retryWrites=true&w=majority

# JWT secret (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# App URL (used in password-reset emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Primary SP Dashboard base URL
NEXT_PUBLIC_SP_DASHBOARD_URL=https://sp-dashboard-eta.vercel.app

# Email / SMTP (Gmail example — use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SP Workstation <noreply@anandrathiwealth.in>"

# When true, OTP / reset links are also returned in API responses (local testing only)
EMAIL_DEV_MODE=true
